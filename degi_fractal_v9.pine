// © Battugs - Degi Fractal Structure v11
// Бүс → Шилжүүлэгч (олон лааны impulse) → PB загвар (1р/2р/3р) → Entry

//@version=5
indicator("Degi Fractal Structure", "DFS", overlay=true, max_boxes_count=50, max_lines_count=200, max_labels_count=100)

// ══════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════
var g1 = "Тохиргоо"
i_atr_len    = input.int(14, "ATR Length", group=g1)
i_disp_mult  = input.float(1.5, "Шилжүүлэгч эхлэх ATR x", minval=1.0, maxval=5.0, step=0.1, group=g1)
i_fib_ext    = input.int(15, "Fibo шугам урт", minval=3, maxval=50, group=g1)
i_lookback   = input.int(20, "Бүс lookback", minval=5, maxval=60, group=g1)
i_max_range  = input.float(5.0, "Бүс max range (ATR x)", minval=2.0, maxval=10.0, step=0.5, group=g1)
i_cooldown   = input.int(20, "Cooldown (bars)", minval=5, maxval=50, group=g1)

var g2 = "Multi-Timeframe"
i_htf1 = input.timeframe("30", "30 min", group=g2)
i_htf2 = input.timeframe("60", "1H", group=g2)
i_htf3 = input.timeframe("240", "4H", group=g2)
i_htf4 = input.timeframe("D", "Daily", group=g2)

var g3 = "Өнгө"
i_col_zone = input.color(color.new(#787b86, 80), "Бүс", group=g3)
i_col_fibo = input.color(#363a45, "Fibo", group=g3)

// ══════════════════════════════════════════════════════════════
// CORE
// ══════════════════════════════════════════════════════════════
atr_val   = ta.atr(i_atr_len)
body_size = math.abs(close - open)

prev_hi = ta.highest(high[1], i_lookback)
prev_lo = ta.lowest(low[1], i_lookback)
prev_range = prev_hi - prev_lo
was_ranging = prev_range < atr_val * i_max_range

// Глобал scope дээр дуудах (Pine Script шаардлага)
_local_range_5 = ta.highest(high, 5) - ta.lowest(low, 5)
_local_hi_5 = ta.highest(high, 5)
_local_lo_5 = ta.lowest(low, 5)
_recent_hi_5 = ta.highest(high, 5)[1]
_recent_lo_5 = ta.lowest(low, 5)[1]

var int last_signal_bar = 0
in_cooldown = bar_index - last_signal_bar < i_cooldown

// ══════════════════════════════════════════════════════════════
// ШИЛЖҮҮЛЭГЧ TRACKING
// ══════════════════════════════════════════════════════════════
var int   track_state      = 0
var float track_extreme    = na
var float track_zone_hi    = na
var float track_zone_lo    = na
var int   track_start      = 0
var int   track_zone_start = 0

// PB + Entry state
var int   active_pattern   = 0
var int   disp_dir         = 0
var float disp_extreme     = na
var float disp_zone_lo     = na   // Шилжүүлэгчийн бүсийн утгууд хадгалах
var float disp_zone_hi     = na
var int   bars_since_disp  = 0
var bool  pb_started       = false
var int   prev_cd          = 0
var label pb_label         = na

// PB дотоод бүтэц
var int   pb_start_bar     = 0
var int   pb_waves         = 0
var int   pb_wave_dir      = 0
var float pb_swing_hi      = na
var float pb_swing_lo      = na
var float pb_deepest       = na
// PB дотоод Fractal (1р загварт)
var bool  pb_inner_ranging = false
var bool  pb_inner_disp    = false
var bool  pb_inner_pb_done = false
var int   pb_inner_range_bars = 0
var float pb_inner_range_hi = na
var float pb_inner_range_lo = na
// PB давалгааны хэмжээ (3р загварт)
var float pb_w1 = 0.0
var float pb_w2 = 0.0
var float pb_w3 = 0.0
var float pb_w_start = na

if disp_dir != 0
    bars_since_disp += 1

// Tracking эхлүүлэх
is_big_bull = body_size > atr_val * i_disp_mult and close > open
is_big_bear = body_size > atr_val * i_disp_mult and close < open

if track_state == 0 and not in_cooldown
    if is_big_bull and was_ranging and close > prev_hi
        track_state      := 1
        track_extreme    := high
        track_zone_hi    := prev_hi
        track_zone_lo    := prev_lo
        track_start      := bar_index
        track_zone_start := bar_index - i_lookback

    if is_big_bear and was_ranging and close < prev_lo
        track_state      := -1
        track_extreme    := low
        track_zone_hi    := prev_hi
        track_zone_lo    := prev_lo
        track_start      := bar_index
        track_zone_start := bar_index - i_lookback

// Fibo зурах
draw_fibo(pt_0, pt_2, b_start) =>
    pt_1 = (pt_0 + pt_2) / 2
    b_end = b_start + i_fib_ext
    line.new(b_start, pt_0, b_end, pt_0, color=i_col_fibo, width=2)
    label.new(b_start - 1, pt_0, "0 ", style=label.style_label_right, color=color.new(color.white, 100), textcolor=i_col_fibo, size=size.small)
    line.new(b_start, pt_1, b_end, pt_1, color=i_col_fibo, width=2)
    label.new(b_start - 1, pt_1, "1 ", style=label.style_label_right, color=color.new(color.white, 100), textcolor=i_col_fibo, size=size.small)
    line.new(b_start, pt_2, b_end, pt_2, color=i_col_fibo, width=2)
    label.new(b_start - 1, pt_2, "2 ", style=label.style_label_right, color=color.new(color.white, 100), textcolor=i_col_fibo, size=size.small)
    pt_1

// Шилжүүлэгч баталгаа
validate_disp(zone_edge, extreme, zone_range, bars_used) =>
    disp_range = math.abs(extreme - zone_edge)
    disp_range >= zone_range and bars_used <= 10 and disp_range >= zone_range * 0.5

// ══════════════════════════════════════════════════════════════
// BULLISH TRACKING
// ══════════════════════════════════════════════════════════════
if track_state == 1
    track_extreme := math.max(track_extreme, high)
    // Дуусах: бүтэн биеэр эсрэг хаагдсан (sweep = үргэлжилнэ)
    body_lo = math.min(open, close)
    prev_body_lo = math.min(open[1], close[1])
    full_reversal = close < open and body_lo < prev_body_lo
    if full_reversal
        zone_range = track_zone_hi - track_zone_lo
        bars_used = bar_index - track_start
        if validate_disp(track_zone_lo, track_extreme, zone_range, bars_used)
            box.new(track_zone_start, track_zone_hi, track_start, track_zone_lo, bgcolor=i_col_zone, border_color=color.new(#787b86, 40), border_width=1)
            draw_fibo(track_zone_lo, track_extreme, bar_index)
            disp_dir       := 1
            disp_extreme   := track_extreme
            disp_zone_lo   := track_zone_lo
            disp_zone_hi   := track_zone_hi
            bars_since_disp := 0
            pb_started     := false
            active_pattern := 0
            last_signal_bar := bar_index
            pb_label       := na
        else
            disp_dir       := 0
            pb_started     := false
            active_pattern := 0
            last_signal_bar := bar_index
            pb_label       := na
        track_state := 0

// ══════════════════════════════════════════════════════════════
// BEARISH TRACKING
// ══════════════════════════════════════════════════════════════
if track_state == -1
    track_extreme := math.min(track_extreme, low)
    body_hi = math.max(open, close)
    prev_body_hi = math.max(open[1], close[1])
    full_reversal = close > open and body_hi > prev_body_hi
    if full_reversal
        zone_range = track_zone_hi - track_zone_lo
        bars_used = bar_index - track_start
        if validate_disp(track_zone_hi, track_extreme, zone_range, bars_used)
            box.new(track_zone_start, track_zone_hi, track_start, track_zone_lo, bgcolor=i_col_zone, border_color=color.new(#787b86, 40), border_width=1)
            draw_fibo(track_zone_hi, track_extreme, bar_index)
            disp_dir       := -1
            disp_extreme   := track_extreme
            disp_zone_lo   := track_zone_lo
            disp_zone_hi   := track_zone_hi
            bars_since_disp := 0
            pb_started     := false
            active_pattern := 0
            last_signal_bar := bar_index
            pb_label       := na
        else
            disp_dir       := 0
            pb_started     := false
            active_pattern := 0
            last_signal_bar := bar_index
            pb_label       := na
        track_state := 0

// ══════════════════════════════════════════════════════════════
// PB ЗАГВАР + ENTRY
// ══════════════════════════════════════════════════════════════
// 2р (candle-butesh3): V хэлбэр, дотроо бүтэц байхгүй, шууд sharp reversal
// 1р (candle-butesh2): PB дотроо бүтэн Fractal (range → шилжүүлэгч → PB → impulse)
// 3р (candle-butesh):  3 давалгаа, 3-р нь 1р загварын бүтэцтэй
//
// ЯЛГАХ АРГА: Бүтцээр — bar тоогоор биш!
// 2р = дотроо range ч, шилжүүлэгч ч үүсэхгүй, зүгээр V
// 1р = PB дотроо range үүсч + тэр range-г PB чиглэлд шилжүүлэгч эвдэж + дараа нь буцсан
// 3р = 3+ давалгаа ба давалгаа дотроо 1р бүтэц олдсон

if disp_dir != 0 and bars_since_disp > 0 and active_pattern == 0
    cur_cd = close > open ? 1 : -1
    disp_mid = disp_dir == 1 ? (disp_zone_lo + disp_extreme) / 2 : (disp_zone_hi + disp_extreme) / 2

    // ── PB эхлэх ──
    if not pb_started
        pb_trigger = disp_dir == 1 ? (close < open) : (close > open)
        if pb_trigger
            pb_started         := true
            pb_start_bar       := bar_index
            pb_swing_hi        := high
            pb_swing_lo        := low
            pb_deepest         := disp_dir == 1 ? low : high
            pb_waves           := 1
            pb_wave_dir        := -disp_dir
            pb_inner_ranging   := false
            pb_inner_disp      := false
            pb_inner_pb_done   := false
            pb_inner_range_bars := 0
            pb_inner_range_hi  := na
            pb_inner_range_lo  := na
            pb_w1 := 0.0
            pb_w2 := 0.0
            pb_w3 := 0.0
            pb_w_start := close

    // PB байхгүй
    if not pb_started and bars_since_disp > 10
        active_pattern := 0
        disp_dir := 0  // Reset, шинэ бүтэц хайна

    // ── PB идэвхитэй ──
    if pb_started and active_pattern == 0
        pb_swing_hi := math.max(pb_swing_hi, high)
        pb_swing_lo := math.min(pb_swing_lo, low)
        if disp_dir == 1 and low < pb_deepest
            pb_deepest := low
        if disp_dir == -1 and high > pb_deepest
            pb_deepest := high

        // Давалгаа тоолох — зөвхөн ТОДОРХОЙ хэмжээний лааг тооцно
        // Жижиг doji, жижиг эсрэг лаа = давалгаа биш
        is_significant = body_size > atr_val * 0.3
        if cur_cd != pb_wave_dir and pb_wave_dir != 0 and is_significant
            w_sz = math.abs(close - pb_w_start)
            if pb_waves == 1
                pb_w1 := w_sz
            else if pb_waves == 2
                pb_w2 := w_sz
            else if pb_waves >= 3
                pb_w3 := w_sz
            pb_waves += 1
            pb_w_start := close
        if is_significant
            pb_wave_dir := cur_cd

        pb_bars = bar_index - pb_start_bar

        // ── PB дотоод Fractal бүтэц хянах (1р загварт) ──
        // 1. Range: PB дотор ханш нарийхан range-д хөдөлж байна уу
        pb_local_range = _local_range_5
        if pb_local_range < atr_val * 2.5 and pb_waves >= 2 and not pb_inner_ranging
            pb_inner_ranging   := true
            pb_inner_range_bars := 0
            pb_inner_range_hi  := _local_hi_5
            pb_inner_range_lo  := _local_lo_5

        // Range баталгаажуулах (3+ бар range дотор)
        if pb_inner_ranging and not pb_inner_disp
            pb_inner_range_bars += 1

        // 2. Дотоод шилжүүлэгч: range-г PB-н ЧИГЛЭЛД бүтэн биеэр эвдсэн
        if pb_inner_ranging and not pb_inner_disp and pb_inner_range_bars >= 3
            if disp_dir == 1  // Bull displacement → PB доошоо → дотоод шилжүүлэгч ДООШОО
                inner_range_sz = nz(pb_inner_range_hi) - nz(pb_inner_range_lo)
                if close < open and body_size > inner_range_sz * 0.4 and close < nz(pb_inner_range_lo)
                    pb_inner_disp := true
            else  // Bear displacement → PB дээшээ → дотоод шилжүүлэгч ДЭЭШЭЭ
                inner_range_sz = nz(pb_inner_range_hi) - nz(pb_inner_range_lo)
                if close > open and body_size > inner_range_sz * 0.4 and close > nz(pb_inner_range_hi)
                    pb_inner_disp := true

        // 3. Дотоод PB: дотоод шилжүүлэгчийн дараа ЭСРЭГ лаа хаагдсан
        if pb_inner_disp and not pb_inner_pb_done
            if disp_dir == 1 and close > open   // Bull лаа = дотоод PB
                pb_inner_pb_done := true
            if disp_dir == -1 and close < open
                pb_inner_pb_done := true

        // ── ЗАГВАР ТОДОРХОЙЛОХ ──
        has_fractal = pb_inner_ranging and pb_inner_disp  // Дотроо Fractal бүтэц
        is_pat1 = has_fractal
        is_pat2 = not has_fractal and pb_waves <= 3
        is_pat3 = not has_fractal and pb_waves >= 4

        cur_pat = is_pat1 ? 1 : is_pat2 ? 2 : is_pat3 ? 3 : 0
        pat_txt = cur_pat == 1 ? "? 1р" : cur_pat == 2 ? "? 2р" : cur_pat == 3 ? "? 3р" : "? PB"
        tip_txt = "Загвар: " + str.tostring(cur_pat) + "р | Бар: " + str.tostring(pb_bars) + "\nДавалгаа: " + str.tostring(pb_waves) + "\nДотоод range: " + (pb_inner_ranging ? "✓" : "✗") + " | Шилжүүлэгч: " + (pb_inner_disp ? "✓" : "✗") + " | PB: " + (pb_inner_pb_done ? "✓" : "✗")

        lbl_y = disp_dir == 1 ? pb_swing_lo - atr_val * 0.3 : pb_swing_hi + atr_val * 0.3
        lbl_style = disp_dir == 1 ? label.style_label_up : label.style_label_down

        if na(pb_label)
            pb_label := label.new(bar_index, lbl_y, pat_txt, style=lbl_style, color=color.new(#2962ff, 60), textcolor=color.white, size=size.small, tooltip=tip_txt)
        else
            label.set_x(pb_label, bar_index)
            label.set_y(pb_label, lbl_y)
            label.set_text(pb_label, pat_txt)
            label.set_tooltip(pb_label, tip_txt)

        // ── ENTRY ──
        // Entry = PB дууссан = шилжүүлэгчийн чиглэлд буцсан
        // Шалгуур: сүүлийн 5 барын swing-г эвдсэн + тухайн чиглэлийн лаа
        entry_ok = false

        if disp_dir == 1
            recent_swing = _recent_hi_5
            if close > recent_swing and close > open
                // 2р: Fractal бүтэц байхгүй, V буцсан
                if is_pat2
                    entry_ok := true
                    active_pattern := 2
                // 1р: Дотоод Fractal дуусаж inner PB буцсан
                if is_pat1 and pb_inner_pb_done
                    entry_ok := true
                    active_pattern := 1
                // 3р: 4+ давалгааны дараа буцсан
                if is_pat3
                    entry_ok := true
                    active_pattern := 3

        if disp_dir == -1
            recent_swing = _recent_lo_5
            if close < recent_swing and close < open
                if is_pat2
                    entry_ok := true
                    active_pattern := 2
                if is_pat1 and pb_inner_pb_done
                    entry_ok := true
                    active_pattern := 1
                if is_pat3
                    entry_ok := true
                    active_pattern := 3

        if entry_ok
            e_col = disp_dir == 1 ? color.new(#089981, 0) : color.new(#f23645, 0)
            e_arrow = disp_dir == 1 ? "▲" : "▼"
            e_txt = str.tostring(active_pattern) + "р загвар " + e_arrow + " ENTRY"
            e_tip = "Загвар: " + str.tostring(active_pattern) + "р\nДавалгаа: " + str.tostring(pb_waves) + " | Бар: " + str.tostring(pb_bars) + "\n" + (active_pattern == 1 ? "Fractal бүтэц: range→шилжүүлэгч→PB дууссан" : active_pattern == 2 ? "V хэлбэр: шууд гүн ороод буцсан" : "3 давалгаа дуусгасан")
            e_y = disp_dir == 1 ? low - atr_val * 0.5 : high + atr_val * 0.5
            if not na(pb_label)
                label.set_text(pb_label, e_txt)
                label.set_color(pb_label, e_col)
                label.set_tooltip(pb_label, e_tip)
                label.set_x(pb_label, bar_index)
                label.set_y(pb_label, e_y)
            pb_label := na

    prev_cd := cur_cd

// ══════════════════════════════════════════════════════════════
// MTF TABLE
// ══════════════════════════════════════════════════════════════
detect_pattern(o, h, l, c) =>
    body = math.abs(c - o)
    full = h - l
    body_r = full > 0 ? body / full : 0
    pb_wick = c > o ? (o - l) : (h - o)
    pb_r = full > 0 ? pb_wick / full : 0
    body_r > 0.7 ? 2 : (pb_r > 0.15 and pb_r < 0.45 and body_r > 0.35) ? 1 : 3

htf1_o = request.security(syminfo.tickerid, i_htf1, open)
htf1_h = request.security(syminfo.tickerid, i_htf1, high)
htf1_l = request.security(syminfo.tickerid, i_htf1, low)
htf1_c = request.security(syminfo.tickerid, i_htf1, close)
htf2_o = request.security(syminfo.tickerid, i_htf2, open)
htf2_h = request.security(syminfo.tickerid, i_htf2, high)
htf2_l = request.security(syminfo.tickerid, i_htf2, low)
htf2_c = request.security(syminfo.tickerid, i_htf2, close)
htf3_o = request.security(syminfo.tickerid, i_htf3, open)
htf3_h = request.security(syminfo.tickerid, i_htf3, high)
htf3_l = request.security(syminfo.tickerid, i_htf3, low)
htf3_c = request.security(syminfo.tickerid, i_htf3, close)
htf4_o = request.security(syminfo.tickerid, i_htf4, open)
htf4_h = request.security(syminfo.tickerid, i_htf4, high)
htf4_l = request.security(syminfo.tickerid, i_htf4, low)
htf4_c = request.security(syminfo.tickerid, i_htf4, close)

p1 = detect_pattern(htf1_o, htf1_h, htf1_l, htf1_c)
p2 = detect_pattern(htf2_o, htf2_h, htf2_l, htf2_c)
p3 = detect_pattern(htf3_o, htf3_h, htf3_l, htf3_c)
p4 = detect_pattern(htf4_o, htf4_h, htf4_l, htf4_c)

pat_str(p) => p == 1 ? "1р загвар" : p == 2 ? "2р загвар" : "3р загвар"
dir_col(o, c) => c > o ? #089981 : #f23645
dir_str(o, c) => c > o ? " ▲" : " ▼"

var table tbl = table.new(position.top_right, 2, 5, bgcolor=color.new(#1e1e1e, 5), border_width=1, border_color=color.new(color.gray, 70))

if barstate.islast
    table.cell(tbl, 0, 0, "Цаг", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 0, "Лааны бүтэц", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 0, 1, "30m" + dir_str(htf1_o, htf1_c), text_color=dir_col(htf1_o, htf1_c), text_size=size.small)
    table.cell(tbl, 1, 1, pat_str(p1), text_color=color.white, text_size=size.small)
    table.cell(tbl, 0, 2, "1H" + dir_str(htf2_o, htf2_c), text_color=dir_col(htf2_o, htf2_c), text_size=size.small)
    table.cell(tbl, 1, 2, pat_str(p2), text_color=color.white, text_size=size.small)
    table.cell(tbl, 0, 3, "4H" + dir_str(htf3_o, htf3_c), text_color=dir_col(htf3_o, htf3_c), text_size=size.small)
    table.cell(tbl, 1, 3, pat_str(p3), text_color=color.white, text_size=size.small)
    table.cell(tbl, 0, 4, "D" + dir_str(htf4_o, htf4_c), text_color=dir_col(htf4_o, htf4_c), text_size=size.small)
    table.cell(tbl, 1, 4, pat_str(p4), text_color=color.white, text_size=size.small)

alertcondition(track_state == 1 and track_state[1] == 0, "Bull Шилжүүлэгч", "Bullish шилжүүлэгч")
alertcondition(track_state == -1 and track_state[1] == 0, "Bear Шилжүүлэгч", "Bearish шилжүүлэгч")
