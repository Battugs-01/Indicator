// © Battugs - TBM Strategy v6
// 61.8 сэтлэсэн = трэнд эргэлт → MOM олох → Fibo

//@version=5
indicator("TBM Strategy", "TBM", overlay=true, max_lines_count=100, max_labels_count=50)

// ══════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════
i_swing_len = input.int(5, "Swing Length", minval=2, maxval=20)
i_atr_len   = input.int(14, "ATR Length")
i_fib_len   = input.int(30, "Fibo шугам урт", minval=5, maxval=80)
i_max_fibs  = input.int(3, "Max Fibo тоо", minval=1, maxval=6)

i_col_fibo  = input.color(#000000, "Fibo 0, 1 (хар)")
i_col_mom   = input.color(#ef5350, "MOM (улаан)")
i_col_618   = input.color(#ef5350, "61.8")

// ══════════════════════════════════════════════════════════════
// CORE
// ══════════════════════════════════════════════════════════════
atr_val = ta.atr(i_atr_len)

ph = ta.pivothigh(high, i_swing_len, i_swing_len)
pl = ta.pivotlow(low, i_swing_len, i_swing_len)

// Swing хадгалах
var float[] sh_p = array.new_float(0)
var int[]   sh_b = array.new_int(0)
var float[] sl_p = array.new_float(0)
var int[]   sl_b = array.new_int(0)

if not na(ph)
    array.push(sh_p, ph)
    array.push(sh_b, bar_index - i_swing_len)
    if array.size(sh_p) > 30
        array.shift(sh_p)
        array.shift(sh_b)

if not na(pl)
    array.push(sl_p, pl)
    array.push(sl_b, bar_index - i_swing_len)
    if array.size(sl_p) > 30
        array.shift(sl_p)
        array.shift(sl_b)

// Хуучин fibo устгах
var line[] fib_lines = array.new_line(0)
var label[] fib_labels = array.new_label(0)

clean_old() =>
    while array.size(fib_lines) > i_max_fibs * 5
        line.delete(array.shift(fib_lines))
    while array.size(fib_labels) > i_max_fibs * 3
        label.delete(array.shift(fib_labels))

// ══════════════════════════════════════════════════════════════
// ТРЭНДИЙН ЭРГЭЛТ ОЛОХ → MOM ТОДОРХОЙЛОХ
// ══════════════════════════════════════════════════════════════
// 1. Impulse хөдөлгөөн олох (swing low → swing high)
// 2. Тэр impulse-н 61.8 тооцох
// 3. PB ирээд 61.8-г СЭТЭЛВЭЛ = трэнд эргэлт!
// 4. Тэр сэтлэсэн ойлтын extreme = MOM
// 5. MOM-с fibo татах
//
// "61.8 сэтлэсэн хөдөлгөөнийг трэндийн эргэлт гэж үзнэ"
// "Тухайн доод буюу 1 цэгийг mom гэж нэрийдээд байгаа"

// Сүүлийн 2 swing-ийн 61.8 тооцох
var float last_imp_hi  = na
var float last_imp_lo  = na
var float last_imp_618 = na
var int   last_imp_dir = 0   // 1=bull impulse, -1=bear impulse

// Шинэ impulse бүртгэх
if not na(ph) and array.size(sl_p) > 0
    // Bull impulse: swing low → swing high
    lo = array.get(sl_p, array.size(sl_p) - 1)
    rng = ph - lo
    if rng > atr_val * 2
        last_imp_hi  := ph
        last_imp_lo  := lo
        last_imp_618 := lo + rng * 0.618
        last_imp_dir := 1

if not na(pl) and array.size(sh_p) > 0
    // Bear impulse: swing high → swing low
    hi = array.get(sh_p, array.size(sh_p) - 1)
    rng = hi - pl
    if rng > atr_val * 2
        last_imp_hi  := hi
        last_imp_lo  := pl
        last_imp_618 := hi - rng * 0.618
        last_imp_dir := -1

// ══════════════════════════════════════════════════════════════
// 61.8 СЭТЛЭСЭН ҮҮ? → ТРЭНД ЭРГЭЛТ → MOM
// ══════════════════════════════════════════════════════════════
var bool  trend_reversed = false
var float mom_price      = na
var int   mom_bar        = 0

// Bull impulse-н 61.8 сэтлэсэн = bear трэнд эргэлт
// (ханш доошоо 61.8-г бүтэн биеэр эвдсэн)
if last_imp_dir == 1 and not na(last_imp_618) and not trend_reversed
    if close < last_imp_618 and close < open and math.min(open, close) < last_imp_618
        trend_reversed := true
        // MOM = тэр сэтлэсэн хөдөлгөөний ойлтын HIGH
        // (сэтлэхээс өмнөх хамгийн ойрын swing high)
        if array.size(sh_p) > 0
            mom_price := array.get(sh_p, array.size(sh_p) - 1)
            mom_bar   := array.get(sh_b, array.size(sh_b) - 1)

            // MOM олдлоо → Fibo татах
            // 0 = impulse-н high (одоогийн swing high)
            // 1 = MOM-с доор (impulse low)
            // MOM = дотоод ойлтын цэг
            fib_0 = last_imp_hi
            fib_1 = last_imp_lo
            fib_range = fib_0 - fib_1
            fib_618 = fib_0 - fib_range * 0.618
            fib_72  = fib_0 - fib_range * 0.72
            fib_end = bar_index + i_fib_len

            // 0 — хар
            l0 = line.new(mom_bar, fib_0, fib_end, fib_0, color=i_col_fibo, width=1)
            array.push(fib_lines, l0)
            // 1 — хар
            l1 = line.new(mom_bar, fib_1, fib_end, fib_1, color=i_col_fibo, width=1)
            array.push(fib_lines, l1)
            // MOM — улаан
            lm = line.new(mom_bar, mom_price, fib_end, mom_price, color=i_col_mom, width=1)
            array.push(fib_lines, lm)
            lb = label.new(fib_end + 1, mom_price, "MOM", style=label.style_label_left, color=color.new(color.white, 100), textcolor=i_col_mom, size=size.tiny)
            array.push(fib_labels, lb)
            // 61.8 — улаан тод
            l618 = line.new(mom_bar, fib_618, fib_end, fib_618, color=i_col_618, width=2)
            array.push(fib_lines, l618)
            // 72
            l72 = line.new(mom_bar, fib_72, fib_end, fib_72, color=i_col_618, style=line.style_dashed, width=1)
            array.push(fib_lines, l72)

            clean_old()

// Bear impulse-н 61.8 сэтлэсэн = bull трэнд эргэлт
if last_imp_dir == -1 and not na(last_imp_618) and not trend_reversed
    if close > last_imp_618 and close > open and math.max(open, close) > last_imp_618
        trend_reversed := true
        if array.size(sl_p) > 0
            mom_price := array.get(sl_p, array.size(sl_p) - 1)
            mom_bar   := array.get(sl_b, array.size(sl_b) - 1)

            fib_0 = last_imp_lo
            fib_1 = last_imp_hi
            fib_range = fib_1 - fib_0
            fib_618 = fib_0 + fib_range * 0.618
            fib_72  = fib_0 + fib_range * 0.72
            fib_end = bar_index + i_fib_len

            l0 = line.new(mom_bar, fib_0, fib_end, fib_0, color=i_col_fibo, width=1)
            array.push(fib_lines, l0)
            l1 = line.new(mom_bar, fib_1, fib_end, fib_1, color=i_col_fibo, width=1)
            array.push(fib_lines, l1)
            lm = line.new(mom_bar, mom_price, fib_end, mom_price, color=i_col_mom, width=1)
            array.push(fib_lines, lm)
            lb = label.new(fib_end + 1, mom_price, "MOM", style=label.style_label_left, color=color.new(color.white, 100), textcolor=i_col_mom, size=size.tiny)
            array.push(fib_labels, lb)
            l618 = line.new(mom_bar, fib_618, fib_end, fib_618, color=i_col_618, width=2)
            array.push(fib_lines, l618)
            l72 = line.new(mom_bar, fib_72, fib_end, fib_72, color=i_col_618, style=line.style_dashed, width=1)
            array.push(fib_lines, l72)

            clean_old()

// Шинэ impulse гарахад trend_reversed reset
if not na(ph) or not na(pl)
    trend_reversed := false

// ALERTS
alertcondition(trend_reversed, "Трэнд эргэлт", "61.8 сэтлэгдлээ — трэнд эргэлт + MOM")
